#!/usr/bin/env bash
# spec-vc · prepare-commit-msg shim
# Version: 0.2.0
set -euo pipefail
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
PYTHON_BIN=${PYTHON_BIN:-python3}
export PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m spec_vc.cli hook prepare-commit-msg "$1" "${2:-}" "${3:-}"
