#!/usr/bin/env bash
# spec-vc · commit-msg shim
# Version: 0.3.0
set -euo pipefail

# 优先使用 PATH 中的 spec-vc
if command -v spec-vc &>/dev/null; then
    exec spec-vc hook commit-msg "$1"
fi

# Fallback: init 时写入的 venv 绝对路径
SPEC_VC_BIN="{{SPEC_VC_BIN}}"
if [[ -x "$SPEC_VC_BIN" ]]; then
    exec "$SPEC_VC_BIN" hook commit-msg "$1"
fi

echo "[spec-vc] 致命：找不到 spec-vc 可执行文件" >&2
exit 1
