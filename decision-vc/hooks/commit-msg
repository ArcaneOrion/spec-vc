#!/usr/bin/env bash
# decision-vc · commit-msg (严格模式)
# Version: 0.1.0
# Source: decision-vc skill
#
# 校验 commit message 必须包含 [ADR-NNN] 或 [ADR-none]。
# [ADR-NNN] 必须引用 doc/arch/adr-NNN.md 中存在的 ADR,且状态未被废弃。
# [ADR-none] 必须符合 check_exemption 的豁免规则。
#
# 参数:
#   $1 = commit message 文件路径
#
# 可覆盖环境变量:
#   ADR_DIR      ADR 目录(默认 doc/arch)
#   DVC_DEBUG=1  打印调试信息

set -euo pipefail

COMMIT_MSG_FILE="$1"
ADR_DIR="${ADR_DIR:-doc/arch}"

debug() { [[ "${DVC_DEBUG:-0}" == "1" ]] && echo "[dvc-debug] $*" >&2; return 0; }

# 读取首行(subject),剥除行内注释
SUBJECT=$(head -n1 "$COMMIT_MSG_FILE" | sed 's/#.*$//')
debug "SUBJECT=[${SUBJECT}]"

# ---- 1. 检查标记存在 ----
if ! echo "$SUBJECT" | grep -qE '\[ADR-(none|[0-9]{3,})\]'; then
    # 辅助识别未填充的槽位,给更友好提示
    if echo "$SUBJECT" | grep -qE '\[ADR-\?+\]'; then
        cat >&2 <<'EOF'
[decision-vc] Commit 被阻塞:检测到未填充的槽位 [ADR-???]

请把 [ADR-???] 替换为:
  - [ADR-NNN]  引用具体 ADR(NNN 为三位零填充编号,如 007)
  - [ADR-none] 显式豁免(仅限不影响架构的改动)

运行 /decision-vc list 查看可用 ADR 编号
EOF
    else
        cat >&2 <<'EOF'
[decision-vc] Commit 被阻塞:subject 必须包含 [ADR-NNN] 或 [ADR-none]

示例:
    feat(auth): 引入 LDAP 客户端 [ADR-007]
    docs: 修正拼写 [ADR-none]

运行 /decision-vc list 查看可用 ADR 编号
或使用 [ADR-none] 显式豁免(仅限不影响架构的改动)
EOF
    fi
    exit 1
fi

# ---- 2. 提取 ADR 引用 ----
ADR_REF=$(echo "$SUBJECT" | grep -oE '\[ADR-(none|[0-9]{3,})\]' | head -n1)
ADR_ID=$(echo "$ADR_REF" | sed -E 's/\[ADR-(.*)\]/\1/')

# ---- 3. 分支:none 走豁免规则,NNN 走存在性校验 ----
if [[ "$ADR_ID" == "none" ]]; then
    # TODO(human): 实现严格模式下的豁免规则 check_exemption
    #
    # 背景:[ADR-none] 是"显式豁免"标记,表示本次 commit 不涉及架构决策。
    # 如果完全开放,严格模式就失去意义(大家都写 [ADR-none] 糊过去);
    # 如果完全封闭,日常小改动(修拼写、升级 patch 依赖)会被阻塞。
    #
    # 你要实现的函数:check_exemption
    #   输入:暂存区已改动的文件列表(git diff --cached --name-only)
    #   输出:
    #     - 0  允许豁免(放行 commit)
    #     - 1  不允许豁免(阻塞 commit 并打印理由)
    #
    # 参考思路(选一或组合):
    #   (a) 路径白名单:只有改动 README.md / *.md / .github/ 等文档路径才允许
    #   (b) 路径黑名单:只要触及 src/ / lib/ / core/ 就拒绝豁免
    #   (c) 扩展名白名单:只允许 .md / .txt / .gitignore / package-lock.json 等
    #   (d) 依赖变化豁免:package.json 里只有 patch 级版本号变化
    #   (e) commit 大小阈值:改动 < N 行
    #
    # 请在下方实现 check_exemption 函数,然后把占位 return 0 改成真实判定。
    #
    # 当前是占位实现——直接放行,意味着 [ADR-none] 暂时无任何约束。
    # 实现完毕后,请删除此 TODO(human) 块。

    check_exemption() {
        # TODO(human): 在此实现豁免规则
        return 0
    }

    if check_exemption; then
        exit 0
    else
        echo "[decision-vc] [ADR-none] 不符合豁免规则,请创建 ADR 或调整改动范围" >&2
        exit 1
    fi
fi

# ---- 4. [ADR-NNN] 校验文件存在 ----
ADR_FILE="${ADR_DIR}/adr-${ADR_ID}.md"
if [[ ! -f "$ADR_FILE" ]]; then
    cat >&2 <<EOF
[decision-vc] Commit 被阻塞:引用的 ADR 不存在
    ${ADR_REF} → ${ADR_FILE} (not found)

请确认编号正确,或运行 /decision-vc new "<标题>" 创建新 ADR
EOF
    exit 1
fi

# ---- 5. 校验 ADR 状态不是 Deprecated / Superseded ----
#
# 模板中 Status 行格式:`- **Status**: <state>`
# 正则修正点(相比 v0.0):
#   (1) 不再要求行首是 `**Status**`(模板带 `- ` 前缀,原 `^` 导致永远失败)
#   (2) 允许 `Superseded by ADR-NNN` 这种多词状态,用 `[A-Za-z][A-Za-z ]*` 而非 `\w+`
#   (3) 只取第一个匹配到的 Status 行(防止 body 中出现 "**Status**" 字样干扰)
STATUS=$(grep -m1 -oE '\*\*Status\*\*:\s*[A-Za-z][A-Za-z ]*' "$ADR_FILE" \
         | sed -E 's/\*\*Status\*\*:\s*//' \
         | sed -E 's/[[:space:]]+$//' \
         || echo "")
debug "STATUS=[${STATUS}]"

case "${STATUS}" in
    Deprecated|"Superseded"|"Superseded by"*)
        cat >&2 <<EOF
[decision-vc] Commit 被阻塞:ADR-${ADR_ID} 状态为 "${STATUS}",不应再被引用

如确需基于历史决策做补充修正:
  - 创建新 ADR 替代之,或
  - 使用 [ADR-none] 并在 commit body 中说明历史上下文
EOF
        exit 1
        ;;
esac

exit 0
